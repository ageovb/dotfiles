{{- $resolvedProvider := "harui@private" -}}
{{- $model := "gpt-5.3-codex" -}}
{{- $modelRef := printf "%s/%s" $resolvedProvider $model -}}
{{- $providerKeys := list "proxy@private" -}}
{{- $providerApiKeys := dict -}}
{{- range $providerKey := $providerKeys -}}
{{-   $providerApiPath := printf "opencode/%s/api_key" (replace "@" "/" $providerKey) -}}
{{-   $providerApiKeyCmd := printf "command -v gopass >/dev/null 2>&1 || exit 0; p='%s'; if gopass list -f \"$p\" >/dev/null 2>&1; then gopass show --password \"$p\" | head -n 1; fi" $providerApiPath -}}
{{-   $_ := set $providerApiKeys $providerKey ((output "sh" "-c" $providerApiKeyCmd) | trim) -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "theme": "dracula",
  "model": {{ $modelRef | quote }},
  "small_model": {{ $modelRef | quote }},
  "instructions": [
    "AGENTS.md",
    ".opencode/AGENTS.md"
  ],
  "command": {
    "doctor-all": {
      "description": "Run all AI account diagnostics and summarize findings.",
      "agent": "build",
      "template": "Run `claude-manage doctor`, `codex-manage doctor`, and `opencode mcp list`. Report failures first, then warnings, then concrete remediation steps. If Tavily / Context7 / Serena MCP is missing from OpenCode output, include remediation to restore `mcp.tavily`, `mcp.context7`, and `mcp.serena` in opencode config and re-run `chezmoi apply`."
    },
    "spec-verify": {
      "description": "Validate current OpenSpec change and repository tests.",
      "agent": "build",
      "template": "Run `openspec validate <change-name>` and `bash tests/run.sh`. Report failing commands with likely root causes."
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "model": {{ $modelRef | quote }},
      "variant": "xhigh",
      "options": {
        "store": false
      },
      "description": "Default implementation agent for daily coding work."
    },
    "plan": {
      "model": {{ $modelRef | quote }},
      "variant": "xhigh",
      "options": {
        "store": false
      },
      "description": "Planning agent for multi-step and spec-first tasks."
    }
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.direnv/**",
      "**/.cache/**",
      "**/.sisyphus/**"
    ]
  },
  "lsp": {
    "rust-analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "lua-language-server": {
      "command": ["lua-language-server"],
      "extensions": [".lua"]
    },
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py"],
      "disabled": true
    }
  },
  "formatter": {
    "rustfmt": {
      "command": ["rustfmt"],
      "extensions": [".rs"]
    },
    "ruff-format": {
      "command": ["ruff", "format"],
      "extensions": [".py"]
    },
    "prettier": {
      "command": ["prettier", "--write"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".md", ".yaml", ".yml"],
      "disabled": true
    },
    "stylua": {
      "command": ["stylua"],
      "extensions": [".lua"],
      "disabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384
  },
  "share": "manual",
  "autoupdate": "notify",
  "tui": {
    "diff_style": "auto",
    "scroll_speed": 2.5,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "provider": {
    "proxy@private": {
      "name": "proxy@private",
      "env": ["PROXY_API_KEY"],
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"{{- if ne (get $providerApiKeys "proxy@private") "" }},
        "apiKey": {{ get $providerApiKeys "proxy@private" | quote }}{{- end }}
      },
      "models": {
        "claude-opus": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "claude-opus",
          "variants": {
            "high": {
              "effort": "high"
            },
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            }
          }
        },
        "claude-sonnet": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "claude-sonnet",
          "variants": {
            "high": {
              "thinking": {
                "budgetTokens": 18000,
                "type": "enabled"
              }
            },
            "low": {
              "thinking": {
                "budgetTokens": 5000,
                "type": "enabled"
              }
            },
            "medium": {
              "thinking": {
                "budgetTokens": 13000,
                "type": "enabled"
              }
            }
          }
        },
        "gemini-flash": {
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
              "video",
              "audio"
            ],
            "output": [
              "text"
            ]
          },
          "name": "gemini-flash",
          "variants": {
            "high": {
              "thinkingConfig": {
                "includeThoughts": true,
                "thinkingLevel": "high"
              }
            },
            "low": {
              "thinkingConfig": {
                "includeThoughts": true,
                "thinkingLevel": "low"
              }
            },
            "medium": {
              "thinkingConfig": {
                "includeThoughts": true,
                "thinkingLevel": "medium"
              }
            }
          }
        },
        "gemini-pro": {
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
              "video",
              "audio"
            ],
            "output": [
              "text"
            ]
          },
          "name": "gemini-pro",
          "variants": {
            "high": {
              "thinkingConfig": {
                "includeThoughts": true,
                "thinkingLevel": "high"
              }
            },
            "low": {
              "thinkingConfig": {
                "includeThoughts": true,
                "thinkingLevel": "low"
              }
            }
          }
        },
        "glm": {
          "limit": {
            "context": 204800,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "name": "glm"
        },
        "gpt": {
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "gpt",
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-codex": {
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "gpt-codex",
          "options": {
            "include": [
              "reasoning.encrypted_content"
            ],
            "store": false
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            }
          }
        },
        "kimi": {
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "name": "kimi"
        },
        "minimax": {
          "limit": {
            "context": 204800,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "name": "minimax"
        }
      },
    },
  },
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "plugin": [
    "oh-my-opencode",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "tavily": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.local/bin/mcp-tavily"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.local/bin/mcp-context7"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide", "--project", ".", "--enable-web-dashboard", "false"],
      "enabled": true
    },
    "gitmcp": {
      "type": "remote",
      "url": "https://gitmcp.io/docs",
      "oauth": false,
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "lsp": "ask",
    "task": "ask",
    "skill": "ask",
    "doom_loop": "ask"
  }
}
